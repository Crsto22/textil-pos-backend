MYSQL_ROOT_PASSWORD=change_me_root_admin_password
DB_USERNAME=sistema_textil_app
DB_PASSWORD=change_me_app_password
DB_URL=jdbc:mysql://mysql:3306/sistema_textil?useSSL=false&serverTimezone=America/Lima&allowPublicKeyRetrieval=true

JWT_SECRET=change_me_at_least_32_chars_random_secret
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7
COOKIE_SECURE=true
COOKIE_DOMAIN=
COOKIE_SAME_SITE=Lax
CORS_ALLOWED_ORIGINS=https://tu-dominio-frontend.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_MAX_AGE=3600
JPA_SHOW_SQL=false

AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_S3_SUNAT_BUCKET=
AWS_S3_SUNAT_PREFIX=sunat

SUNAT_MODE=disabled
SUNAT_CERT_BASE_PATH=/app/storage/sunat/certificados
SUNAT_CERT_MAX_FILE_SIZE_MB=5
SUNAT_CRYPTO_KEY=change_me_32_chars_minimum_random_secret
DASHBOARD_SUNAT_HEALTH_TIMEOUT_MS=5000
DASHBOARD_SUNAT_HEALTH_CACHE_TTL_SECONDS=60
APIPERU_TOKEN=
